# ══════════════════════════════════════════════════════════════════════════════
# DocMind IA — Variables de entorno para producción (Railway)
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el .env con valores reales al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente al agregar el plugin PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname
RUNNING_IN_DOCKER=true

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Mínimo 64 caracteres hexadecimales. NUNCA reutilizar entre entornos.
SECRET_KEY=genera-una-clave-segura-de-64-caracteres-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
# En producción usar Railway MinIO o cualquier proveedor S3-compatible.
MINIO_ENDPOINT=tu-minio-endpoint:9000
MINIO_PUBLIC_ENDPOINT=tu-minio-endpoint-publico:9000
MINIO_ACCESS_KEY=tu-access-key
MINIO_SECRET_KEY=tu-secret-key
MINIO_BUCKET=docmind-docs
MINIO_SECURE=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos. En producción limitar al dominio del frontend.
# Ejemplo: ["https://docmind-frontend.railway.app"]
ALLOWED_ORIGINS=["https://tu-frontend.railway.app"]

# ── Entorno ────────────────────────────────────────────────────────────────────
# Con ENVIRONMENT=production: /docs, /redoc y /openapi.json quedan deshabilitados.
ENVIRONMENT=production
