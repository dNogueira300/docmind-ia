# ══════════════════════════════════════════════════════════════════════════════
# DocMind IA — Variables de entorno para producción (Railway)
# Copia las claves a las Variables de cada servicio en Railway y completa los
# valores reales en el dashboard. NUNCA subas valores reales al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway genera DATABASE_URL automáticamente al añadir el plugin Postgres.
# Referénciala en el backend como ${{Postgres.DATABASE_URL}}.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Solo para desarrollo/tests sin Docker. En Railway NO se define.
# DATABASE_URL_LOCAL=postgresql://user:password@localhost:5433/dbname
# Debe ser true para que config.py use DATABASE_URL (no la local).
RUNNING_IN_DOCKER=true

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Mínimo 64 caracteres hexadecimales. NUNCA reutilizar entre entornos.
SECRET_KEY=genera-una-clave-segura-de-64-caracteres-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
# Endpoint INTERNO (red privada Railway): el backend lo usa para subir/leer/borrar.
# Ej: ${{MinIO.RAILWAY_PRIVATE_DOMAIN}}:9000  → algo.railway.internal:9000
MINIO_ENDPOINT=minio.railway.internal:9000
# Endpoint PÚBLICO (resoluble por el browser): solo para firmar URLs de descarga.
# Ej: el dominio público que Railway asigna al servicio MinIO (sin esquema).
MINIO_PUBLIC_ENDPOINT=tu-minio-publico.up.railway.app
MINIO_ACCESS_KEY=tu-access-key
MINIO_SECRET_KEY=tu-secret-key
MINIO_BUCKET=docmind-docs
# TLS del endpoint interno (red privada Railway → normalmente sin TLS).
MINIO_SECURE=false
# TLS del endpoint público. Railway expone HTTPS → poner true en producción.
MINIO_PUBLIC_SECURE=true

# ── CORS ───────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos. En producción limitar al dominio del frontend.
ALLOWED_ORIGINS=["https://tu-frontend.up.railway.app"]

# ── Entorno ────────────────────────────────────────────────────────────────────
# Con ENVIRONMENT=production: /docs, /redoc y /openapi.json quedan deshabilitados.
ENVIRONMENT=production

# ── Bootstrap del super administrador ───────────────────────────────────────────
# El backend crea este usuario en el primer arranque si no existe ninguno.
# En producción SUPER_ADMIN_PASSWORD es OBLIGATORIO (sin él no se crea el admin).
SUPER_ADMIN_EMAIL=superadmin@tudominio.com
SUPER_ADMIN_PASSWORD=define-una-contraseña-fuerte

# ── Google Gemini API (resumen + chatbot) ───────────────────────────────────────
# Obtener en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-gemini-api-key

# ── NLP (clasificación zero-shot) ────────────────────────────────────────────────
# Opcional. Si se omite, se elige por entorno: producción usa el modelo ligero
# (MiniLMv2-L6, menos RAM); desarrollo usa el pesado (mDeBERTa-base). Solo definir
# para forzar un modelo concreto.
# NLP_MODEL=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli
